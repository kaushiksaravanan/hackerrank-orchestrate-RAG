# Copy this file to .env and fill in your API key.
# `ANTHROPIC_API_KEY` is the standard variable name.
# `HAI_API_KEY` is also supported for the local proxy setup used in this repo.
ANTHROPIC_API_KEY=your_api_key_here
HAI_API_KEY=your_api_key_here

# Optional Hugging Face token for higher rate limits / private model access.
# The code also accepts HF_TOKEN and other common HF variable names.
HG_TOKEN=your_huggingface_token_here

# Anthropic API base URL (local proxy)
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic

# Embedding model (ONNX). Falls back to bge-base then bge-small then TF-IDF.
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# HuggingFace Inference API model (fallback LLM when Anthropic proxy is down)
HF_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
